PORT=5000

# AI provider: use openai for lower-cost text advice by default.
AI_PROVIDER=openai

# OpenAI Responses API configuration.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano
# OPENAI_API_ENDPOINT=https://api.openai.com

# Backend AI request cap per API key/IP.
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=12

# Vertex AI API-key configuration for local testing.
# Use an express mode API key or a service-account-bound Google Cloud API key.
VERTEX_API_KEY=your_vertex_api_key_here
VERTEX_API_ENDPOINT=https://aiplatform.googleapis.com
# GOOGLE_GENAI_USE_VERTEXAI=true

# Google Cloud Vertex AI ADC/service-account configuration.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash-lite

# For local Vertex AI development only. On Cloud Run, use the service account instead.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

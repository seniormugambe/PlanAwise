# Google Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.5-flash-lite

# Frontend API base URL.
# Leave empty for local dev/preview so Vite proxies /api to the backend.
# Set this to your deployed backend URL in production, for example https://your-backend.run.app.
VITE_API_URL=

# Local Vite proxy target used when VITE_API_URL is empty.
VITE_API_PROXY_TARGET=http://localhost:5000

# Web3 Configuration
# Get your WalletConnect project ID from: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# RPC Provider API Keys (optional, for better performance)
# Get Alchemy API key from: https://www.alchemy.com
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here
# Get Infura API key from: https://infura.io
VITE_INFURA_API_KEY=your_infura_api_key_here

# Optional: Set to 'development' for additional logging
VITE_APP_ENV=production
